# Docker config
# prod: Dockerfile, dev: Dockerfile.dev
DOCKERFILE=Dockerfile.dev
ENABLE_CACHE=true
ENABLE_DB=true
RUST_LOG=info

# Postgres
POSTGRES_DB=myrtle
POSTGRES_USER=myrtle
POSTGRES_PASSWORD=myrtle

# Backend
DATABASE_URL=postgres://myrtle:myrtle@postgres:5432/myrtle
REDIS_URL=redis://redis:6379

DATA_DIR=/data/Unpacked/decoded/gamedata/excel
ASSETS_DIR=/data/Unpacked

JWT_SECRET=sample-jwt-secret-key
INTERNAL_SERVICE_KEY=sample-internal-service-key

# S3-Compatible Storage for assets in backend (optional)
# Set ASSET_MODE to enable S3: "local" (default), "s3", or "hybrid"
ASSET_MODE="local"
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PATH_STYLE="true"
S3_PREFIX=""

# Frontend
# Follows schema in frontend/src/env.js
BACKEND_URL=http://backend:3060

# Workaround profile
COMPOSE_PROFILES=true
